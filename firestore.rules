// firestore.rules
//
// Deploy with: firebase deploy --only firestore:rules
// Or paste directly in Firebase console → Firestore → Rules tab.

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ───────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      // Reads the custom claim set by set-admin-claim.js
      // Cannot be spoofed by the client.
      return isSignedIn() && request.auth.token.role == "admin";
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // ── Subjects (shared across all users) ────────────────────────
    // Admins can write. Any signed-in user can read.
    match /subjects/{docId} {
      allow read:  if isSignedIn();
      allow write: if isAdmin();
    }

    // ── Scores (per-user) ─────────────────────────────────────────
    // Each user can only read and write their own scores document.
    // Admins can read any user's scores (for reporting).
    match /scores/{uid} {
      allow read:  if isOwner(uid) || isAdmin();
      allow write: if isOwner(uid);
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
